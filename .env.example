# ─────────────────────────────────────────────────────────────────────────────
# Zikra — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=zikra_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ai_cortex
POSTGRES_PORT=5432

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# Public URL for n8n (must end with /)
# Local:  http://localhost:5678/
# Remote: https://n8n.yourdomain.com/
WEBHOOK_URL=http://localhost:5678/
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_PORT=5678

# Encryption key for n8n credentials storage (min 32 chars)
N8N_ENCRYPTION_KEY=change_this_to_a_random_32_char_string

# ── Zikra ─────────────────────────────────────────────────────────────────────
# Secret token used by all agents to authenticate with the Zikra webhook.
# Generate with: openssl rand -hex 32
ZIKRA_TOKEN=your-secret-token

# Full webhook URL that agents will POST to.
# Must match WEBHOOK_URL above + the webhook path from the n8n workflow.
ZIKRA_WEBHOOK_URL=http://localhost:5678/webhook/zikra

# ── AI / Embeddings ───────────────────────────────────────────────────────────
# Required for semantic (vector) search. Leave blank to use keyword search only.
OPENAI_API_KEY=sk-...

# Optional: use a different embedding model or a local proxy (e.g. LiteLLM)
# OPENAI_API_BASE=https://api.openai.com/v1
# ZIKRA_EMBEDDING_MODEL=text-embedding-3-small

# ── Optional: LiteLLM proxy ───────────────────────────────────────────────────
# If you route embeddings through LiteLLM, set OPENAI_API_BASE to your proxy.
# LITELLM_API_KEY=sk-1234567890
# OPENAI_API_BASE=http://localhost:4000
