#!/usr/bin/env bash
# zikra — CLI for Zikra AI persistent memory
# Usage: zikra <command> [args...]
#
# Patched by install.sh with your webhook URL, token, and project.

set -euo pipefail

ZIKRA_URL="ZIKRA_URL_PLACEHOLDER"
ZIKRA_TOKEN="ZIKRA_TOKEN_PLACEHOLDER"
DEFAULT_PROJECT="DEFAULT_PROJECT_PLACEHOLDER"
CACHE_FILE="$HOME/.claude/cache/zikra-stats.json"
ZIKRA_RAW="https://raw.githubusercontent.com/getzikra/zikra/main"

RUNNER="$(hostname -s 2>/dev/null || hostname 2>/dev/null || echo "unknown")"

# ── POST helper ───────────────────────────────────────────────────────────────
zikra_post() {
  curl -s -X POST "$ZIKRA_URL" \
    -H "Authorization: Bearer $ZIKRA_TOKEN" \
    -H "Content-Type: application/json" \
    -H "User-Agent: curl/7.81.0" \
    --connect-timeout 15 \
    -d "$1"
}

# ── Commands ──────────────────────────────────────────────────────────────────

CMD="${1:-help}"
shift || true

case "$CMD" in

  # ── search ────────────────────────────────────────────────────────────────
  search)
    QUERY="${*:-}"
    if [[ -z "$QUERY" ]]; then
      echo "Usage: zikra search <query>" >&2
      exit 1
    fi

    BODY="$(python3 -c "
import json, sys
print(json.dumps({
    'command':     'search',
    'query':       sys.argv[1],
    'project':     '$DEFAULT_PROJECT',
    'max_results': 5,
}))" "$QUERY")"

    RESP="$(zikra_post "$BODY")"

    echo "$RESP" | python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
except Exception:
    print('Error: could not parse response')
    sys.exit(1)

results = d.get('results') or d.get('memories') or []
if not results:
    print('No results found.')
    sys.exit(0)

for r in results:
    title  = r.get('title', '(no title)')
    mtype  = r.get('memory_type') or r.get('type', '?')
    score  = r.get('score') or r.get('similarity')
    score_s = f'  [{score:.3f}]' if isinstance(score, float) else ''
    print(f'  {mtype:<14}  {title}{score_s}')
"
    ;;

  # ── save ──────────────────────────────────────────────────────────────────
  save)
    TITLE="${*:-}"
    if [[ -z "$TITLE" ]]; then
      echo "Usage: zikra save <title>" >&2
      exit 1
    fi

    printf "Memory type? (decision/error/schema/prompt/conversation) [decision]: "
    read -r MTYPE
    MTYPE="${MTYPE:-decision}"

    if [[ -t 0 ]]; then
      # Interactive — open editor
      TMPFILE="$(mktemp /tmp/zikra_save_XXXXXX.md)"
      echo "# $TITLE" > "$TMPFILE"
      echo "" >> "$TMPFILE"
      "${EDITOR:-vi}" "$TMPFILE"
      CONTENT="$(cat "$TMPFILE")"
      rm -f "$TMPFILE"
    else
      CONTENT="$(cat)"
    fi

    if [[ -z "$CONTENT" ]]; then
      echo "Aborted — no content." >&2
      exit 1
    fi

    BODY="$(python3 -c "
import json, sys
print(json.dumps({
    'command':     'save_memory',
    'project':     '$DEFAULT_PROJECT',
    'memory_type': sys.argv[1],
    'title':       sys.argv[2],
    'content_md':  sys.argv[3],
    'tags':        None,
    'created_by':  '$RUNNER',
}))" "$MTYPE" "$TITLE" "$CONTENT")"

    RESP="$(zikra_post "$BODY")"
    ID="$(echo "$RESP" | python3 -c \
      "import json,sys; print(json.load(sys.stdin).get('id','?'))" 2>/dev/null || echo "?")"
    echo "✓ Saved (${MTYPE}) — id: ${ID}"
    ;;

  # ── status ────────────────────────────────────────────────────────────────
  status)
    echo "── Local cache ──────────────────────────────────"
    if [[ -f "$CACHE_FILE" ]]; then
      python3 -c "
import json
with open('$CACHE_FILE') as f:
    d = json.load(f)
print(f\"  runs_today:    {d.get('runs_today',   0)}\")
print(f\"  runs_total:    {d.get('runs_total',   0)}\")
print(f\"  memory_count:  {d.get('memory_count', 0)}\")
print(f\"  updated_at:    {d.get('updated_at',   '(never)')}\")
"
    else
      echo "  (cache not found — install with --full profile to enable)"
    fi

    echo ""
    echo "── Webhook reachability ─────────────────────────"
    BODY="{\"command\":\"search\",\"query\":\"ping\",\"project\":\"${DEFAULT_PROJECT}\",\"max_results\":1}"
    HTTP="$(curl -s -o /dev/null -w "%{http_code}" \
      -X POST "$ZIKRA_URL" \
      -H "Authorization: Bearer $ZIKRA_TOKEN" \
      -H "Content-Type: application/json" \
      -H "User-Agent: curl/7.81.0" \
      --connect-timeout 10 \
      -d "$BODY" 2>/dev/null || echo "000")"

    if [[ "$HTTP" == "200" ]]; then
      echo "  ✓ Webhook reachable (HTTP 200)"
    else
      echo "  ✗ Webhook returned HTTP ${HTTP} — check ZIKRA_URL and ZIKRA_TOKEN"
    fi
    ;;

  # ── run ───────────────────────────────────────────────────────────────────
  run)
    PROMPT_NAME="${1:-}"
    if [[ -z "$PROMPT_NAME" ]]; then
      echo "Usage: zikra run <prompt_name>" >&2
      exit 1
    fi

    BODY="$(python3 -c "
import json, sys
print(json.dumps({
    'command':     'get_prompt',
    'prompt_name': sys.argv[1],
    'project':     '$DEFAULT_PROJECT',
    'runner':      '$RUNNER',
}))" "$PROMPT_NAME")"

    RESP="$(zikra_post "$BODY")"

    # Store run_id for watcher linkage
    RUN_ID="$(echo "$RESP" | python3 -c \
      "import json,sys; print(json.load(sys.stdin).get('run_id',''))" 2>/dev/null || true)"
    [[ -n "$RUN_ID" ]] && echo "$RUN_ID" > /tmp/zikra_prompt_id

    # Print prompt content
    echo "$RESP" | python3 -c "
import json, sys
try:
    d = json.load(sys.stdin)
except Exception:
    sys.exit(1)
content = d.get('content_md') or d.get('prompt') or d.get('content', '')
if content:
    print(content)
else:
    print(json.dumps(d, indent=2))
"
    ;;

  # ── log ───────────────────────────────────────────────────────────────────
  log)
    SUMMARY="${*:-Session ended}"
    BODY="$(python3 -c "
import json, sys
print(json.dumps({
    'command':               'log_run',
    'project':               '$DEFAULT_PROJECT',
    'runner':                '$RUNNER',
    'status':                'success',
    'output_summary':        sys.argv[1],
    'tokens_input':          0,
    'tokens_output':         0,
    'tokens_cache_read':     0,
    'tokens_cache_creation': 0,
}))" "$SUMMARY")"

    zikra_post "$BODY" > /dev/null
    echo "✓ Run logged"
    ;;

  # ── error ─────────────────────────────────────────────────────────────────
  error)
    TITLE="${*:-}"
    if [[ -z "$TITLE" ]]; then
      echo "Usage: zikra error <title>  (pipe detail on stdin)" >&2
      exit 1
    fi

    if [[ -t 0 ]]; then
      echo "Enter error detail (Ctrl-D to finish):"
      DETAIL="$(cat)"
    else
      DETAIL="$(cat)"
    fi

    BODY="$(python3 -c "
import json, sys
print(json.dumps({
    'command':    'log_error',
    'project':    '$DEFAULT_PROJECT',
    'title':      sys.argv[1],
    'content_md': sys.argv[2],
}))" "$TITLE" "$DETAIL")"

    zikra_post "$BODY" > /dev/null
    echo "✓ Error logged — title: $TITLE"
    ;;

  # ── sync ──────────────────────────────────────────────────────────────────
  sync)
    echo "Re-downloading and running install.sh from $ZIKRA_RAW..."
    curl -fsSL "$ZIKRA_RAW/install.sh" | bash
    ;;

  # ── help ──────────────────────────────────────────────────────────────────
  help|--help|-h|"")
    cat <<'HELP'
zikra — AI Persistent Memory CLI

Commands:
  zikra search <query>         Search memories (top 5)
  zikra save <title>           Save a memory (stdin or $EDITOR)
  zikra status                 Local stats + webhook health check
  zikra run <prompt_name>      Fetch and print a stored prompt
  zikra log <summary>          Log a run manually
  zikra error <title>          Log an error (detail from stdin)
  zikra sync                   Re-run installer from latest install.sh
  zikra help                   Show this help

Runtime overrides (environment):
  ZIKRA_URL      Webhook URL
  ZIKRA_TOKEN    Bearer token

HELP
    ;;

  *)
    echo "Unknown command: $CMD  (try: zikra help)" >&2
    exit 1
    ;;

esac
